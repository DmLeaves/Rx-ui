# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_size = 4

[*.js]
indent_size = 2

[*.ts]
indent_size = 2

[*.vue]
indent_size = 2

[*.html]
indent_size = 2

[*.css]
indent_size = 2

[*.json]
indent_size = 2

[*.yaml]
indent_size = 2
indent_style = space

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab